# Pivot numeric measures into long format for plotting
df_plot <- df_long %>%
pivot_longer(
cols = c(pw, mr, sr, cf),
names_to = "measure",
values_to = "score"
) %>%
mutate(
measure = recode(
measure,
cf = "counterfactual",
pw = "praiseworthiness",
mr = "moral requirement",
sr = "social expectation"
)
)
# Faceted boxplot
ggplot(df_plot, aes(x = gender, y = score, fill = gender)) +
geom_violin(trim = TRUE, alpha = 0.6) +  # violin plot
stat_summary(
fun = mean,
geom = "point",
shape = 23,        # diamond
size = 3,
color = "black",
fill = "yellow"
) +
facet_wrap(~ measure, scales = "free_y") +
scale_fill_manual(values = c("m" = "#1f77b4", "f" = "#ff7f0e")) +
labs(
x = "Gender (Agent)",
y = "Score",
fill = ""
) +
theme_minimal(base_size = 14) +
theme(legend.position = "none")
df_long <- df_long %>%
mutate(risk = as.factor(ifelse(group %in% c("discrimination", "physicalC"), "high", "low")))
res <- aov(pw ~ risk, data = df_long)
aov_tab <- summary(res)[[1]]
F_val  <- aov_tab["risk", "F value"]
df1    <- aov_tab["risk", "Df"]
df2    <- aov_tab["Residuals", "Df"]
p_val  <- aov_tab["risk", "Pr(>F)"]
# Effect size: eta squared
eta2 <- aov_tab["risk", "Sum Sq"] / sum(aov_tab[, "Sum Sq"])
# Pivot numeric measures into long format for plotting
ggplot(df_long, aes(x = group, y = mr)) +
geom_boxplot(alpha = 0.6) +  # violin plot
labs(
x = "Vignette",
y = "Score"
) +
theme_minimal(base_size = 14) +
theme(legend.position = "bottom")
# Pivot numeric measures into long format for plotting
ggplot(df_long, aes(x = group, y = sr)) +
geom_boxplot(trim = TRUE, alpha = 0.6) +  # violin plot
labs(
x = "Vignette",
y = "Score"
) +
theme_minimal(base_size = 14) +
theme(legend.position = "bottom")
# 1. Correlation
cor_res <- cor(df_long$mr, df_long$sr, use = "complete.obs")
cor_res_test <- cor.test(df_long$mr, df_long$sr)
# 2. Linear model with interaction (moderation by group)
mod_int <- lm(sr ~ mr * group, data = df_long)
mod_int_summary <- summary(mod_int)
# Extract key statistics for reporting
interaction_terms <- mod_int_summary$coefficients[grep("mr:group", rownames(mod_int_summary$coefficients)), ]
interaction_p <- max(interaction_terms[, "Pr(>|t|)"])  # largest p-value among interactions
r_squared <- mod_int_summary$r.squared
# Binarize praiseworthiness and counterfactual blame
df_long <- df_long %>%
mutate(
pw_bin = ifelse(pw > 0, 1, 0),   # 1 = praiseworthy, 0 = blameworthy
cf_bin = ifelse(cf < 0, 1, 0)    # 1 = blameworthy, 0 = not blameworthy
)
# Logistic regression: cf_bin ~ pw_bin
glm_cf <- glm(cf_bin ~ pw_bin, family = binomial, data = df_long)
summary_glm_cf <- summary(glm_cf)
# Extract coefficient and odds ratio
coef_pw <- coef(summary_glm_cf)["pw_bin", "Estimate"]
se_pw   <- coef(summary_glm_cf)["pw_bin", "Std. Error"]
z_pw    <- coef(summary_glm_cf)["pw_bin", "z value"]
p_pw    <- coef(summary_glm_cf)["pw_bin", "Pr(>|z|)"]
or_pw   <- exp(coef_pw)
# Step 1: mediator models (continuous)
mod_mr <- lm(mr ~ pw, data = df_long)
mod_sr <- lm(sr ~ pw, data = df_long)
# Step 2: outcome model (binary)
mod_cf <- glm(cf_bin ~ pw + mr + sr, family = binomial, data = df_long)
# Step 3: mediation analysis
med_mr <- mediate(mod_mr, mod_cf, treat = "pw", mediator = "mr", sims = 1000)
med_sr <- mediate(mod_sr, mod_cf, treat = "pw", mediator = "sr", sims = 1000)
# Extract key stats
acme_mr <- med_mr$d0
acme_sr <- med_sr$d0
ade_mr  <- med_mr$z0
ade_sr  <- med_sr$z0
total_mr <- med_mr$tau.coef
total_sr <- med_sr$tau.coef
# Make sure gender is a factor
df_long <- df_long %>%
mutate(gender = factor(gender, levels = c("m", "f")))
# Continuous outcomes
lm_pw <- lm(pw ~ gender, data = df_long)
lm_mr <- lm(mr ~ gender, data = df_long)
lm_sr <- lm(sr ~ gender, data = df_long)
lm_cf <- lm(cf ~ gender, data = df_long)
library(effectsize)
library(broom)
# List of models
models <- list(
pw = lm(pw ~ gender * group, data = df_long),
mr = lm(mr ~ gender * group, data = df_long),
sr = lm(sr ~ gender * group, data = df_long),
cf = lm(cf ~ gender * group, data = df_long)
)
# Function to extract coefficients and partial eta squared
extract_model_table <- function(mod, outcome_name) {
coefs <- tidy(mod) %>%
filter(term != "(Intercept)") %>%  # optional
select(term, estimate, std.error, statistic, p.value) %>%
mutate(outcome = outcome_name)
return(coefs)
}
# Combine all models
summary_table <- bind_rows(
extract_model_table(models$pw, "pw"),
extract_model_table(models$mr, "mr"),
extract_model_table(models$sr, "sr"),
extract_model_table(models$cf, "cf")
) %>%
select(outcome, term, estimate, std.error, statistic, p.value)
# Round for readability
summary_table <- summary_table %>%
mutate(across(c(estimate, std.error, statistic), ~round(., 3)),
p.value = round(p.value, 3))
library(kableExtra)
summary_table %>%
kbl(caption = "Gender × Group Effects Across Outcomes") %>%
kable_styling(full_width = FALSE)
GEpw = lm(pw ~ gender * genderParticipant, data = df_long)
GEmr = lm(mr ~ gender * genderParticipant, data = df_long)
GEsr = lm(sr ~ gender * genderParticipant, data = df_long)
GEcf = lm(cf ~ gender * genderParticipant, data = df_long)
# Create a new data frame with all combinations of gender and genderParticipant
newdata <- expand.grid(
gender = unique(df_long$gender),
genderParticipant = unique(df_long$genderParticipant)
)
# Function to get predictions with confidence intervals
get_preds <- function(model, newdata, model_name) {
preds <- predict(model, newdata, interval = "confidence", level = 0.95)
df <- cbind(newdata, as.data.frame(preds))
df$model <- model_name
df %>% rename(predicted = fit, lower = lwr, upper = upr)
}
# Get predictions with confidence intervals for all models
pred_pw <- get_preds(GEpw, newdata, "pw")
pred_mr <- get_preds(GEmr, newdata, "mr")
pred_sr <- get_preds(GEsr, newdata, "sr")
pred_cf <- get_preds(GEcf, newdata, "cf")
# Combine all predictions
pred_df <- bind_rows(pred_pw, pred_mr, pred_sr, pred_cf)
# Plot
ggplot(pred_df, aes(x = gender, y = predicted, fill = genderParticipant)) +
geom_bar(stat = "identity", position = position_dodge(width = 0.9)) +
geom_errorbar(aes(ymin = lower, ymax = upper),
position = position_dodge(width = 0.9), width = 0.2) +
facet_wrap(~model, scales = "free_y") +
labs(
y = "Predicted value",
x = "Gender",
fill = "Participant Gender",
title = "Predicted values for each model by gender and participant gender"
) +
theme_minimal()
GEpw = lm(pw ~ gender * genderParticipant, data = df_long)
GEmr = lm(mr ~ gender * genderParticipant, data = df_long)
GEsr = lm(sr ~ gender * genderParticipant, data = df_long)
GEcf = lm(cf ~ gender * genderParticipant, data = df_long)
# Create a new data frame with all combinations of gender and genderParticipant
newdata <- expand.grid(
gender = unique(df_long$gender),
genderParticipant = unique(df_long$genderParticipant)
)
# Function to get predictions with confidence intervals
get_preds <- function(model, newdata, model_name) {
preds <- predict(model, newdata, interval = "confidence", level = 0.95)
df <- cbind(newdata, as.data.frame(preds))
df$model <- model_name
df %>% rename(predicted = fit, lower = lwr, upper = upr)
}
# Get predictions with confidence intervals for all models
pred_pw <- get_preds(GEpw, newdata, "pw")
pred_mr <- get_preds(GEmr, newdata, "mr")
pred_sr <- get_preds(GEsr, newdata, "sr")
pred_cf <- get_preds(GEcf, newdata, "cf")
# Combine all predictions
pred_df <- bind_rows(pred_pw, pred_mr, pred_sr, pred_cf)
# Plot
ggplot(pred_df, aes(x = gender, y = predicted, fill = genderParticipant)) +
geom_bar(stat = "identity", position = position_dodge(width = 0.9)) +
geom_errorbar(aes(ymin = lower, ymax = upper),
position = position_dodge(width = 0.9), width = 0.2) +
facet_wrap(~model, scales = "free_y") +
labs(
y = "Predicted value",
x = "Gender",
fill = "Participant Gender",
title = "Predicted values for each model by gender and participant gender"
) +
theme_minimal()
models <- list(
pw = lm(pw ~ gender * group * genderParticipant, data = df_long),
mr = lm(mr ~ gender * group * genderParticipant, data = df_long),
sr = lm(sr ~ gender * group * genderParticipant, data = df_long),
cf = lm(cf ~ gender * group * genderParticipant, data = df_long)
)
# Create a function to get predictions + 95% CI
get_preds <- function(model, newdata, model_name) {
preds <- predict(model, newdata, interval = "confidence", level = 0.95)
df <- cbind(newdata, as.data.frame(preds))
df$model <- model_name
df %>% rename(predicted = fit, lower = lwr, upper = upr)
}
# Create all combinations of the factors
newdata <- expand.grid(
gender = unique(df_long$gender),
group = unique(df_long$group),
genderParticipant = unique(df_long$genderParticipant)
)
# Apply prediction function to all models
pred_list <- lapply(names(models), function(m) {
get_preds(models[[m]], newdata, m)
})
# Combine predictions into one data frame
pred_df <- bind_rows(pred_list)
# Plot using bars with error bars
ggplot(pred_df, aes(x = gender, y = predicted, fill = genderParticipant)) +
geom_bar(stat = "identity", position = position_dodge(width = 0.9)) +
geom_errorbar(aes(ymin = lower, ymax = upper),
position = position_dodge(width = 0.9), width = 0.2) +
facet_grid(model ~ group, scales = "free_y") +
labs(
y = "Predicted value",
x = "Gender",
fill = "Participant Gender",
title = "Predicted values with 95% CI for 3-way interaction models"
) +
theme_minimal()
pred_df
knitr::opts_chunk$set(echo = F, message = F)
library(dplyr)
library(metafor)
library(esc)
library(readxl)
library(rlang)
library(tidyr)
library(jsonlite)
library(stringr)
library(purrr)
library(knitr)
library(kableExtra)
library(readxl)
rm(list = ls())
setwd(dirname(rstudioapi::getActiveDocumentContext()$path))
helper_files <- list.files("stats_helpers", full.names = T)
for(.file in helper_files) source(.file)
## Read in data
input_path <- "../../input/reported_data_from_selected_papers"
.files <- list.files(input_path, full.names = T)
df <- lapply(.files, function(x){
fromJSON(x, flatten = T)
}) %>%
bind_rows()
## Add columns
df <- df %>%
mutate(id_paper = as.factor(gsub("_.*", "", study)),
id_experiment = as.factor(gsub("\\*.*", "", study)),
id_metric_nested = factor(gsub("(?<=[0-9])[a-z]$", "", study, perl = T)),
scale = as.factor(scale),
measure = as.factor(measure)
) %>%
# Invert means where necessary
mutate(across(c(M1, M2, M3), ~ case_when(
direction == "inverted" ~ max_scale + 1 - .,
TRUE ~ .
)))
## Read in metadata
meta <- read_xlsx("../../input/metadata.xlsx")
meta <- meta %>% mutate(id_experiment = paste0(PaperID, "_", Study)) %>% select(-PaperID, -Study)
all(table(meta$id_experiment) == 1)
## Join data and meta-data
df <- left_join(df, meta)
df <- df %>% mutate(across(c(SampleType, SampleModality, Published, Subjective, Theme), ~ as.factor(.)))
test <- filter(df, study == "67_1*1a")
test
p_vec <- c(test$p1, test$p2, test$p3) %>% na.omit
p_vec
test$N_total
test$bad_outcome
res <- compute_pairwise_prop_to_g(p_vec, test$N_total, test$bad_outcome)
res
p_vec
test <- filter(df, study == "67_1*1b")
test
p_vec <- c(test$p1, test$p2, test$p3) %>% na.omit
p_vec
res <- compute_pairwise_prop_to_g(p_vec, test$N_total, test$bad_outcome)
res
test <- filter(df, study == "67_1*1c")
p_vec <- c(test$p1, test$p2, test$p3) %>% na.omit
res <- compute_pairwise_prop_to_g(p_vec, test$N_total, test$bad_outcome)
res
df <- calc_eff_size(df)
df %>% filter(is.na(yi))
knitr::opts_chunk$set(echo = F, message = F)
